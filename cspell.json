{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/packages/cspell-types/cspell.schema.json",
  "version": "0.2",
  "language": "en,pt-BR",
  "import": ["@cspell/dict-pt-br/cspell-ext.json"],
  "words": [
    // Brand / project names
    "JUPHD",
    "JUPHDCARE",
    "juphd",

    // PT-BR terms not in standard dictionary (ASCII route/code forms or specialized)
    "Protecao", "protecao",
    "Gestao", "gestao",
    "Psicossociais", "psicossociais",
    "Psicossocial", "psicossocial",
    "previsao",

    // Proper nouns (seed data)
    "Mendes",

    // App domain terms
    "checkin", "checkins", "Checkin", "Checkins",
    "endday",
    "sublabel",
    "testid",

    // Tech / stack terms
    "Vite", "vite",
    "Drizzle", "drizzle",
    "wouter",
    "shadcn",
    "lucide",
    "tabler",
    "cspell",
    "Zod", "zod",
    "Radix",
    "tsconfig",
    "tsx",
    "esbuild",
    "tailwindcss",
    "postcss",
    "pnpm",
    "Embla", "embla",
    "cmdk",
    "vaul",
    "replit",
    "Wordmark", "wordmark",
    "memorystore",
    "firewalled",
    "openat",
    "syscalls",
    "openai",
    "esnext",
    "jridgewell",
    "cartesian",
    "displayname",

    // Tabler icon official names (unconventional but intentional)
    "Confuzed",
    "Wrrr",

    // Design / storybook content terms
    "Hierarchia",
    "microprovas",

    // Intentional dummy bcrypt hash used for constant-time comparison
    "invalidhashtopreventtimingattac",

    // cSpell itself
    "streetsidesoftware"
  ],
  "ignoreWords": [],
  "ignorePaths": [
    "node_modules/**",
    "dist/**",
    "build/**",
    ".git/**",
    "package-lock.json",
    "**/*.min.js",
    "**/*.min.css",
    "DOCS/**",
    "replit.md"
  ],
  "overrides": [
    {
      // Relax checking inside TS type annotations and template literals
      "filename": "**/*.{ts,tsx}",
      "ignoreRegExpList": [
        // hex colors
        "#[0-9a-fA-F]{3,8}",
        // tailwind class strings (long utility chains)
        "(?:className|class)=['\"`][^'\"` ]{40,}"
      ]
    }
  ]
}
